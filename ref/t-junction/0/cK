FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      K;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 -3 0 0 1 0 0]; // [mol/L] = [kg0⋅m-3⋅s0⋅K0⋅mol1⋅A0⋅cd0]   
 
cBulk 0.1; 
 
internalField   uniform $cBulk; 
 

internalField   uniform 100000;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value 100000; // only used for restarts
    }

    outlet1
    {
        type            fixedValue;
        value           uniform 100010;
    }

    outlet2
    {
        type            fixedValue;
        value           uniform 100000;
    }

    defaultFaces
    {
        type            zeroGradient;
    }
} 

