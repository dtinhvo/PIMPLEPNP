FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

value 1e2; 
dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 1e2;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value $value;
    }
    outlet
    {
        type            zeroGradient;
    }
    midline
    {
        type symmetryPlane;

    }
    y 
    {
        type empty;
    }
    neutralSide
    {
        type            zeroGradient;
    }
    chargedSide
    {
        type            zeroGradient;

    }
}


